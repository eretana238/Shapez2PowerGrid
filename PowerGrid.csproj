            <HintPath>$(SPZ2_PATH)\UnityEngine.AssetBundleModule.dll</HintPath>
            <Private>False</Private>
        </Reference>
        <Reference Include="HarmonyX">
            <HintPath>C:\Program Files (x86)\Steam\steamapps\workshop\content\2162800\3720742050\0Harmony.dll</HintPath>
            <Private>False</Private>
        </Reference>
        <Reference Include="Unity.Core">
            <HintPath>$(SPZ2_PATH)\Unity.Core.dll</HintPath>
            <Private>False</Private>
        </Reference>
        <Reference Include="SPZPluginsAssembly">
            <HintPath>$(SPZ2_PATH)\SPZPluginsAssembly.dll</HintPath>
